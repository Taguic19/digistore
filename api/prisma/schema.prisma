generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== ENUMS ====================

enum Role {
  CUSTOMER
  SELLER
  ADMIN
}

enum SellerStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

// ==================== USER ====================

model User {
  id        String    @id @default(cuid())
  email     String    @unique
  name      String?
  password  String
  role      Role      @default(CUSTOMER)
  cart      Cart?
  orders    Order[]
  addresses Address[]
  seller    Seller?   // ← if role is SELLER
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")

  @@map("users")
}

// ==================== ADDRESS ====================

model Address {
  id           String   @id @default(cuid())
  userId       String @map("user_id")
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  street       String
  municipality String
  province     String
  postalCode   String @map("postal_code")
  isDefault    Boolean  @default(false) @map("is_default")
  orders       Order[]
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("address")
}

// ==================== SELLER ====================

model Seller {
  id          String       @id @default(cuid())
  userId      String       @unique @map("user_id")
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeName   String       @unique @map("store_name")
  description String?
  logo        String?
  status      SellerStatus @default(PENDING)  // admin approves
  commission  Decimal      @default(0.10) @db.Decimal(4, 2) // 10% platform cut
  products    Product[]
  orders      SellerOrder[]
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at") 

  @@map("sellers")
}

// ==================== CATEGORY ====================

model Category {
  id        String    @id @default(cuid())
  name      String    @unique
  products  Product[]
  createdAt DateTime  @default(now()) @map("created_at")

  @@map("categories")
}

// ==================== PRODUCT ====================

model Product {
  id          String      @id @default(cuid())
  sellerId    String      @map("seller_id")            // ← belongs to a seller
  seller      Seller      @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  categoryId  String      @map("category_id")
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  name        String
  description String?
  price       Decimal     @db.Decimal(10, 2)
  stock       Int         @default(0)
  images      String[]
  isActive    Boolean     @default(true) @map("is_active")   // seller can toggle
  cartItems   CartItem[]  
  orderItems  OrderItem[] 
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  @@map("products")
}

// ==================== CART ====================

model Cart {
  id        String     @id @default(cuid())
  userId    String     @unique @map("user_id")
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     CartItem[] 
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  @@map("cart")
}

model CartItem {
  id        String   @id @default(cuid())
  cartId    String @map("cart_id")
  cart      Cart     @relation(fields: [cartId], references: [id], onDelete: Cascade)
  productId String @map("product_id")
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Int      @default(1)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([cartId, productId])
  @@map("cart_items")
}

// ==================== ORDER ====================

model Order {
  id           String        @id @default(cuid())
  userId       String @map("user_id")
  user         User          @relation(fields: [userId], references: [id], onDelete: Restrict)
  addressId    String @map("address_id")
  address      Address       @relation(fields: [addressId], references: [id], onDelete: Restrict)
  items        OrderItem[]
  sellerOrders SellerOrder[]   // ← split per seller
  status       OrderStatus   @default(PENDING)
  total        Decimal       @db.Decimal(10, 2)
  note         String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@map("orders")
}

// one order can have items from multiple sellers
// so we split it per seller
model SellerOrder {
  id        String      @id @default(cuid())
  orderId   String  @map("order_id")
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerId  String @map("seller_id")
  seller    Seller      @relation(fields: [sellerId], references: [id], onDelete: Restrict)
  items     OrderItem[]
  status    OrderStatus @default(PENDING)  // seller manages their own status
  subtotal  Decimal     @db.Decimal(10, 2) @map("sub_total")
  commission Decimal    @db.Decimal(10, 2) // platform cut
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  @@map("seller_orders")
}

model OrderItem {
  id            String      @id @default(cuid())
  orderId       String @map("order_id")
  order         Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sellerOrderId String @map("seller_order_id")
  sellerOrder   SellerOrder @relation(fields: [sellerOrderId], references: [id], onDelete: Cascade)
  productId     String @map("product_id")
  product       Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity      Int
  price         Decimal     @db.Decimal(10, 2)

  @@map("order_items")
}